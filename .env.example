NODE_ENV=development
OPENDROP_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
OPENDROP_AUTH_MODE=trusted-header
OPENDROP_ALLOWED_EMAIL_DOMAINS=
OPENDROP_DEFAULT_VISIBILITY=public

# SQLite self-hosted mode
OPENDROP_DB_DRIVER=sqlite
SQLITE_PATH=./storage/opendrop.sqlite

# Postgres self-hosted mode
# OPENDROP_DB_DRIVER=postgres
# DATABASE_URL=postgres://opendrop:opendrop@postgres:5432/opendrop

# Trusted header auth, usually set by a reverse proxy/VPN gateway.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
# Runtime-controlled trusted source hosts. Self-hosted deployments usually leave this empty.
TRUSTED_PROXY_HOSTS=
TRUSTED_HEADER_EMAIL=x-opendrop-email
TRUSTED_HEADER_USER_ID=x-opendrop-user-id
TRUSTED_HEADER_NAME=x-opendrop-name
TRUSTED_HEADER_AVATAR=x-opendrop-avatar
TRUSTED_HEADER_LOGIN_URL=
TRUSTED_HEADER_AUTO_PROVISION=true
TRUSTED_HEADER_ALLOW_EMAIL_LINKING=false

# Required only when OPENDROP_AUTH_MODE=oauth. Generate at least 32 random characters.
# BETTER_AUTH_SECRET=

# S3-compatible storage. Set unique credentials before using docker-compose.yml.
MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-me-with-a-long-random-secret
POSTGRES_PASSWORD=replace-me-with-a-long-random-secret
OPENDROP_STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=opendrop
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me-with-a-long-random-secret
S3_FORCE_PATH_STYLE=true

# OAuth providers are optional and may be disabled for VPN deployments.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
