{
  "name": "@opendrop/server",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/server.ts",
    "./app": "./src/app.ts",
    "./cloudflare": "./src/cloudflare.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:cloudflare": "tsc -p tsconfig.cloudflare.json --noEmit",
    "build:cloudflare": "env WRANGLER_LOG_PATH=/tmp/opendrop-wrangler.log bunx wrangler deploy --dry-run --outdir /tmp/opendrop-wrangler-dry-run",
    "deploy:cloudflare": "bunx wrangler deploy",
    "start": "bun src/server.ts"
  },
  "dependencies": {
    "@opendrop/shared": "workspace:*",
    "better-auth": "^1.3.0",
    "hono": "^4.8.0",
    "kysely": "^0.29.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250709.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.24.0"
  }
}
