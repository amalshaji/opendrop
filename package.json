{
  "name": "opendrop-repo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/shared build && bun run --cwd apps/server build && bun run --cwd apps/server check:cloudflare && bun run --cwd apps/web build && bun run --cwd apps/server build:cloudflare && bun run --cwd apps/cli build",
    "check": "bun run --cwd packages/shared check && bun run --cwd apps/server check && bun run --cwd apps/server check:cloudflare && bun run --cwd apps/web check && bun run --cwd apps/cli check",
    "dev": "bun scripts/dev.ts",
    "readme:video": "remotion render remotion/index.ts ReadmeDemo docs/public/readme-demo.gif --codec=gif --every-nth-frame=2 --overwrite",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:auth-http": "vitest run tests/integration/auth-http.test.ts",
    "test:http": "vitest run tests/integration/auth-http.test.ts tests/integration/annotations-http.test.ts tests/integration/upload-publish.test.ts tests/integration/upload-sessions-http.test.ts",
    "test:repositories": "bun tests/integration/bun-repository-contract.ts && vitest run tests/integration/postgres-repository.test.ts",
    "test:postgres": "vitest run tests/integration/postgres-repository.test.ts",
    "test:storage": "vitest run tests/integration/storage-contract.test.ts",
    "test:e2e": "bun scripts/e2e.ts",
    "test:e2e:start": "bun scripts/e2e.ts start",
    "test:e2e:cli": "bun scripts/e2e.ts cli",
    "test:e2e:ui": "bun scripts/e2e.ts ui",
    "test:e2e:down": "bun scripts/e2e.ts down",
    "test:skills": "vitest run tests/unit/skills.test.ts",
    "release:dry-run": "bun scripts/release/dry-run.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@remotion/cli": "4.0.487",
    "@types/node": "^24.0.0",
    "fflate": "^0.8.2",
    "remotion": "4.0.487",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
